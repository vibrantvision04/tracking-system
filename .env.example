# ─── Copy this file to .env and fill in your values ───

# --- Database ---
DB_DSN=postgresql://user:password@host/dbname?sslmode=require

# --- Redis ---
# For Railway internal Redis, use the full URL:
REDIS_URL=redis://default:password@host:6379

# --- Ports ---
GPS_TCP_PORT=5027
HTTP_PORT=8080
WS_PORT=8081

# --- Settings ---
BATCH_SIZE=100
BATCH_TIMEOUT_MS=5000
LOG_LEVEL=info

# --- Go Memory (set in Railway Dashboard, not here) ---
# GOMEMLIMIT=400MiB
# GOGC=50
